# ============================================================
# AI Spend Audit Tool — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (required for saving audits to database)
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Note: The app works without Supabase — audits run locally.
# Supabase is only needed if you want to persist audit results.
